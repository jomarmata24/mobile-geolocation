{
  "name": "projectmata/mobile-geolocation",
  "display_name": "Projectmata Geolocation",
  "namespace": "Geolocation",

  "bridge_functions":  [
    {
      "name": "Geolocation.GetCurrentPosition",
      "android": "com.projectmata.mobilegeolocation.GeolocationPlugin.GetCurrentPosition",
      "ios": "GeolocationPlugin.GetCurrentPosition"
    },
    {
      "name": "Geolocation.RequestPermission",
      "android": "com.projectmata.mobilegeolocation.GeolocationPlugin.RequestPermission",
      "ios": "GeolocationPlugin.RequestPermission"
    }
  ],
   "android": {
    "min_version": 33,
    "permissions": [
      "android.permission.ACCESS_COARSE_LOCATION",
      "android.permission.ACCESS_FINE_LOCATION"
    ],
    "dependencies": {
      "implementation": [
        "com.google.android.gms:play-services-location:21.3.0"
      ]
    }
  },
  "ios": {
    "min_version": "18.2",
    "info_plist": {
      "NSLocationWhenInUseUsageDescription": "This app uses your location to show your current position."
    }
  }
}