{
  "name": "projectmata/mobile-geolocation",
  "description": "Custom geolocation plugin for NativePHP Mobile",
  "type": "nativephp-plugin",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Projectmata\\MobileGeolocation\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Projectmata\\MobileGeolocation\\MobileGeolocationServiceProvider"
      ]
    },
    "nativephp": {
            "manifest": "nativephp.json"
        }
  },
  "require": {
    "php": "^8.1"
  }
}